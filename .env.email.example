# E-posta / SMTP Yapılandırması
# Kopyala: cp .env.email.example .env.local

# Supabase Auth SMTP (Dashboard'da da ayarlanmalı)
# Seçenek 1: Hostinger
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=noreply@resepsiyonistim.com
SMTP_PASS=your-hostinger-email-password
SMTP_SENDER=noreply@resepsiyonistim.com
SMTP_SENDER_NAME=Resepsiyonistim

# Seçenek 2: Resend (alternatif)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxx
# SMTP_SENDER=noreply@resepsiyonistim.com
# SMTP_SENDER_NAME=Resepsiyonistim

# n8n Email (Coolify env)
# N8N_SMTP_HOST=smtp.hostinger.com
# N8N_SMTP_PORT=465
# N8N_SMTP_USER=noreply@resepsiyonistim.com
# N8N_SMTP_PASS=your-password
# N8N_SMTP_SENDER=noreply@resepsiyonistim.com
