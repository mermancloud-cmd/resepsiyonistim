# n8n API root. Examples:
#   https://your-instance.app.n8n.cloud/api/v1
#   https://n8n.example.com/api/v1
N8N_BASE_URL=

# Temporary API key created in n8n Settings > n8n API.
N8N_API_KEY=

# Choose either tag or project. Workflow IDs are also supported for emergency targeting.
N8N_SELECTION_MODE=tag
N8N_TAG=
N8N_PROJECT=
N8N_WORKFLOW_IDS=

# How many recent executions to inspect per workflow.
N8N_EXECUTION_LIMIT=50

# Production deploy safety switch. Set to true only when ready.
N8N_AUTO_DEPLOY=false

# Optional local n8n settings.
N8N_LOCAL_PORT=5678
GENERIC_TIMEZONE=Europe/Istanbul

# Bungalov DB API (SQLite REST API)
BUNGALOV_DB_API_KEY=

# Optional for test scripts. Prefer these over reading Supabase keys from workflow exports.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional Evolution API settings for real end-to-end WhatsApp smoke tests.
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
REAL_WHATSAPP_TEST=false
WHATSAPP_TEST_PHONE=
WHATSAPP_TEST_TEXT=

# Telegram notifications
BUNGALOV_CHAT_ID=
