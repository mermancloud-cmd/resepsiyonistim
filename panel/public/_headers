# Cloudflare Pages Security Headers
# Applied to all responses by Cloudflare Pages edge.
# See: https://developers.cloudflare.com/pages/configuration/headers/

/*
  # ── Core Security Headers ──────────────────────────────────────
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 0
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  X-DNS-Prefetch-Control: on
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.iyzipay.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://*.supabase.in https://sandbox-api.iyzipay.com https://api.iyzipay.com; frame-src https://sandbox-api.iyzipay.com https://api.iyzipay.com https://*.iyzipay.com; object-src 'none'; base-uri 'self'; form-action 'self' https://*.iyzipay.com; frame-ancestors 'none'; upgrade-insecure-requests

# ── Static Assets (long cache, immutable) ───────────────────────
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# ── Auth Pages (never cache) ────────────────────────────────────
/login
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate
  Pragma: no-cache
  Expires: 0

/onboarding
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate
  Pragma: no-cache
  Expires: 0

